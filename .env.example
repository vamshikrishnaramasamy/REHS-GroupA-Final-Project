# Copy this file to .env and fill in real values. Never commit .env.

# Gmail SMTP settings (see NOTIFICATIONS.md for setup steps)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-alert-account@gmail.com
SMTP_APP_PASSWORD=your-16-character-app-password
ALERT_RECIPIENT=where-alerts-should-go@example.com

# Flask session/flash signing key. Generate your own with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here
